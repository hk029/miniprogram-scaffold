{
  "name": "mini-scaffold-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "Taro mini program template",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:swan": "taro build --type swan",
    "build:alipay": "taro build --type alipay",
    "build:tt": "taro build --type tt",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "build:qq": "taro build --type qq",
    "build:jd": "taro build --type jd",
    "build:harmony-hybrid": "taro build --type harmony-hybrid",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:swan": "npm run build:swan -- --watch",
    "dev:alipay": "npm run build:alipay -- --watch",
    "dev:tt": "npm run build:tt -- --watch",
    "dev:h5": "npm run dev:h5",
    "dev:rn": "taro build --type rn --watch",
    "dev:qq": "npm run build:qq -- --watch",
    "dev:jd": "npm run build:jd -- --watch",
    "dev:harmony-hybrid": "npm run build:harmony-hybrid -- --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "dependencies": {
    "@babel/runtime": "^7.21.5",
    "@tarojs/components": "3.6.31",
    "@tarojs/helper": "3.6.31",
    "@tarojs/plugin-platform-weapp": "3.6.31",
    "@tarojs/plugin-platform-h5": "3.6.31",
    "@tarojs/react": "3.6.31",
    "@tarojs/runtime": "3.6.31",
    "@tarojs/shared": "3.6.31",
    "@tarojs/taro": "3.6.31",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.8",
    "@tarojs/cli": "3.6.31",
    "@tarojs/webpack5-runner": "3.6.31",
    "@types/react": "^18.0.0",
    "babel-preset-taro": "3.6.31",
    "eslint": "^8.40.0",
    "eslint-config-taro": "3.6.31",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "stylelint": "^15.6.2",
    "typescript": "^5.1.0"
  }
}